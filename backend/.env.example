# Copy this file to .env and fill in your values
# Also add these as Environment Variables in your Vercel project dashboard

# MongoDB connection string (use MongoDB Atlas for cloud deployments)
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# Name of the MongoDB database
DB_NAME=sanika_portfolio

# Comma-separated list of allowed frontend origins (your Vercel frontend URL)
CORS_ORIGINS=https://your-frontend-url.vercel.app
